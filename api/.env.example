# Life Map API — Environment Variables
# Copy this to api/.env and fill in values. Never commit api/.env.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://hmdrjdkjyhmigpbdeocu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq ──────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_PRIMARY=llama-4-scout-17b-16e-instruct

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CONTEXT_WINDOW=5

# ── GitHub Actions secret names (for reference) ───────────────
# RAILWAY_URL            → the deployed Railway URL (e.g. https://life-map.up.railway.app)
# SUPABASE_URL           → same as above
# SUPABASE_SERVICE_ROLE_KEY → same as above, also used as x-cron-secret
# GROQ_API_KEY           → same as above
